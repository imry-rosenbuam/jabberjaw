# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required: path to the directory where market data (parquet files) will be stored.
# Must end with a trailing slash.
TSDB_DATA=/path/to/your/data/

# Required for FRED data: get a free key at https://fred.stlouisfed.org/api/key
FRED_API_KEY=your_fred_api_key_here
